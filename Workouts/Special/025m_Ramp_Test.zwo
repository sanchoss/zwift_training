<?xml version='1.0' encoding='utf-8'?>
<workout_file>
    <author>AI Coach</author>
    <name>RMP-T 75% pointed TSS</name>
    <description>25min ramp FTP test. 1-min steps from 46% to failure. FTP = 75% of last completed step's power. Quick, repeatable, no pacing needed.</description>
    <sportType>bike</sportType>
    <tags>
        <tag name="FTP" />
        <tag name="Test" />
        <tag name="Ramp" />
    </tags>
    <workout>
        <!-- Phase 1: Easy Warmup — 5 min ramp 40→55% -->
        <Warmup Duration="300" PowerLow="0.40" PowerHigh="0.55">
            <textevent timeoffset="0" message="RAMP TEST! Easy warmup, relax and spin" />
            <textevent timeoffset="120" message="Simple test: power goes up every minute" />
            <textevent timeoffset="240" message="Just ride until you absolutely cannot continue" />
        </Warmup>

        <!-- Phase 2: Ramp Steps — 1 min each, starting at 46%, +6% per step -->
        <!-- Step 1: 46% -->
        <SteadyState Duration="60" Power="0.46">
            <textevent timeoffset="0" message="Step 1 — 46%: very easy, just spinning" />
        </SteadyState>
        <!-- Step 2: 52% -->
        <SteadyState Duration="60" Power="0.52">
            <textevent timeoffset="0" message="Step 2 — 52%: still easy, warming up" />
        </SteadyState>
        <!-- Step 3: 58% -->
        <SteadyState Duration="60" Power="0.58">
            <textevent timeoffset="0" message="Step 3 — 58%: recovery pace" />
        </SteadyState>
        <!-- Step 4: 64% -->
        <SteadyState Duration="60" Power="0.64">
            <textevent timeoffset="0" message="Step 4 — 64%: easy endurance" />
        </SteadyState>
        <!-- Step 5: 70% -->
        <SteadyState Duration="60" Power="0.70">
            <textevent timeoffset="0" message="Step 5 — 70%: moderate endurance" />
        </SteadyState>
        <!-- Step 6: 76% -->
        <SteadyState Duration="60" Power="0.76">
            <textevent timeoffset="0" message="Step 6 — 76%: tempo effort, you should feel it" />
        </SteadyState>
        <!-- Step 7: 82% -->
        <SteadyState Duration="60" Power="0.82">
            <textevent timeoffset="0" message="Step 7 — 82%: getting serious now" />
        </SteadyState>
        <!-- Step 8: 88% -->
        <SteadyState Duration="60" Power="0.88">
            <textevent timeoffset="0" message="Step 8 — 88%: sweet spot, comfortably hard" />
        </SteadyState>
        <!-- Step 9: 94% -->
        <SteadyState Duration="60" Power="0.94">
            <textevent timeoffset="0" message="Step 9 — 94%: just below threshold, breathing hard" />
        </SteadyState>
        <!-- Step 10: 100% -->
        <SteadyState Duration="60" Power="1.00">
            <textevent timeoffset="0" message="Step 10 — 100% FTP! Real test starts NOW" />
            <textevent timeoffset="30" message="Every step from here is above threshold" />
        </SteadyState>
        <!-- Step 11: 106% -->
        <SteadyState Duration="60" Power="1.06">
            <textevent timeoffset="0" message="Step 11 — 106%: above FTP, dig in!" />
        </SteadyState>
        <!-- Step 12: 112% -->
        <SteadyState Duration="60" Power="1.12">
            <textevent timeoffset="0" message="Step 12 — 112%: VO2 Max territory, BREATHE!" />
        </SteadyState>
        <!-- Step 13: 118% -->
        <SteadyState Duration="60" Power="1.18">
            <textevent timeoffset="0" message="Step 13 — 118%: lungs burning, HOLD ON!" />
        </SteadyState>
        <!-- Step 14: 124% -->
        <SteadyState Duration="60" Power="1.24">
            <textevent timeoffset="0" message="Step 14 — 124%: deep suffering, DON'T QUIT!" />
        </SteadyState>
        <!-- Step 15: 130% -->
        <SteadyState Duration="60" Power="1.30">
            <textevent timeoffset="0" message="Step 15 — 130%: absolute limit! Every second counts!" />
            <textevent timeoffset="30" message="HOLD! Your FTP improves with every pedal stroke!" />
        </SteadyState>
        <!-- Step 16: 136% (bonus — most fail before here) -->
        <SteadyState Duration="60" Power="1.36">
            <textevent timeoffset="0" message="Step 16 — 136%: BEAST MODE! Most people are done!" />
        </SteadyState>
        <!-- Step 17: 142% (exceptional) -->
        <SteadyState Duration="60" Power="1.42">
            <textevent timeoffset="0" message="Step 17 — 142%: INCREDIBLE! You're a machine!" />
        </SteadyState>

        <!-- Phase 3: Cooldown — 5 min -->
        <Cooldown Duration="300" PowerLow="0.30" PowerHigh="0.45">
            <textevent timeoffset="0" message="DONE! Easy spin, bring HR down" />
            <textevent timeoffset="30" message="FTP = 75% of the last COMPLETED step's power" />
            <textevent timeoffset="60" message="Example: failed at Step 13 → FTP = 75% × Step 12 power" />
            <textevent timeoffset="120" message="Great effort! Keep spinning to flush lactate" />
            <textevent timeoffset="240" message="Update your FTP in Zwift settings!" />
        </Cooldown>
    </workout>
</workout_file>
