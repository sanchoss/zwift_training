<?xml version='1.0' encoding='utf-8'?>
<workout_file>
    <author>AI Coach</author>
    <name>FTP-T 85% 80TSS</name>
    <description>65min standard Coggan 20-min FTP test. Includes 5-min blowout to flush anaerobic reserves. FreeRide test block — ride your best avg power for 20min, multiply by 0.95 for new FTP.</description>
    <sportType>bike</sportType>
    <tags>
        <tag name="FTP" />
        <tag name="Test" />
    </tags>
    <workout>
        <!-- Phase 1: Easy Warmup — 10 min ramp 40→65% -->
        <Warmup Duration="600" PowerLow="0.40" PowerHigh="0.65">
            <textevent timeoffset="0" message="FTP TEST DAY! Easy warmup, gradual build" />
            <textevent timeoffset="120" message="Smooth pedaling, relax shoulders and jaw" />
            <textevent timeoffset="300" message="Halfway through warmup, loosen up the legs" />
            <textevent timeoffset="480" message="Spin-ups coming next to wake up the legs" />
        </Warmup>

        <!-- Phase 2: Neuromuscular Spin-ups — 3×1min high cadence / 1min normal -->
        <IntervalsT Repeat="3" OnDuration="60" OffDuration="60" OnPower="0.65" OffPower="0.65" Cadence="110" CadenceResting="85">
            <textevent timeoffset="0" message="SPIN-UP! 110rpm+ at easy power — activate muscles" />
            <textevent timeoffset="30" message="Smooth circles, eliminate dead spots" />
            <textevent timeoffset="60" message="Back to normal cadence 85rpm, relax" />
        </IntervalsT>

        <!-- Phase 3: Steady Build — 5 min @ 75% -->
        <SteadyState Duration="300" Power="0.75">
            <textevent timeoffset="0" message="Build to 75% — open the legs, feel the effort" />
            <textevent timeoffset="120" message="Breathing should be moderate, legs warming up" />
            <textevent timeoffset="240" message="5-min BLOWOUT effort coming next — this is KEY" />
        </SteadyState>

        <!-- Phase 4: 5-min Blowout — 105% FTP -->
        <SteadyState Duration="300" Power="1.05">
            <textevent timeoffset="0" message="BLOWOUT @ 105%! Hard but not max — drain anaerobic tank" />
            <textevent timeoffset="60" message="This ensures the 20-min test reflects TRUE aerobic FTP" />
            <textevent timeoffset="120" message="Without this effort, 0.95 multiplier overestimates FTP" />
            <textevent timeoffset="180" message="2min left! Hold steady, controlled suffering" />
            <textevent timeoffset="270" message="Almost done! 10min easy recovery coming" />
        </SteadyState>

        <!-- Phase 5: Full Recovery — 10 min @ 50% -->
        <SteadyState Duration="600" Power="0.50">
            <textevent timeoffset="0" message="Full recovery: easy spin, bring HR down completely" />
            <textevent timeoffset="120" message="Drink water, settle breathing, relax everything" />
            <textevent timeoffset="300" message="Halfway through recovery. Plan your pacing strategy:" />
            <textevent timeoffset="310" message="Start conservative — first 5min slightly below target" />
            <textevent timeoffset="320" message="Build in the middle — steady increase minutes 5-15" />
            <textevent timeoffset="330" message="Empty the tank — last 5min give everything you have" />
            <textevent timeoffset="480" message="2min to test. Deep breaths. You are READY." />
            <textevent timeoffset="540" message="1min! Shift to your gear. Settle your position." />
            <textevent timeoffset="580" message="ERG mode OFF — this is YOUR effort. GO!" />
        </SteadyState>

        <!-- Phase 6: 20-min FTP Test — FreeRide (no ERG) -->
        <FreeRide Duration="1200">
            <textevent timeoffset="0" message="GO! Find your rhythm — don't explode early!" />
            <textevent timeoffset="30" message="Target: highest SUSTAINABLE power for 20 minutes" />
            <textevent timeoffset="60" message="1min done. Settle in, this is a long effort" />
            <textevent timeoffset="180" message="3min — you should feel comfortably hard, not dying" />
            <textevent timeoffset="300" message="5min done, 15 to go — check power, stay STEADY" />
            <textevent timeoffset="420" message="7min — if you can talk in short phrases, good pacing" />
            <textevent timeoffset="600" message="HALFWAY! 10min done. How do you feel?" />
            <textevent timeoffset="610" message="If comfortable: lift power 2-3%. If suffering: hold." />
            <textevent timeoffset="720" message="12min — dig in. The real test starts NOW." />
            <textevent timeoffset="840" message="14min — 6min left. You can hold ANYTHING for 6min!" />
            <textevent timeoffset="900" message="15min — FINAL QUARTER! Start building to finish" />
            <textevent timeoffset="960" message="4 MIN LEFT! Time to push harder" />
            <textevent timeoffset="1020" message="3 MIN! Dig deep, this is where FTP is built" />
            <textevent timeoffset="1080" message="LAST 2 MINUTES! Everything you've got!" />
            <textevent timeoffset="1140" message="FINAL MINUTE! ALL OUT! Leave nothing!" />
            <textevent timeoffset="1170" message="30 SECONDS! SPRINT TO THE LINE!" />
            <textevent timeoffset="1195" message="DONE! Incredible effort!" />
        </FreeRide>

        <!-- Phase 7: Cooldown — 10 min ramp 50→35% -->
        <Cooldown Duration="600" PowerLow="0.35" PowerHigh="0.50">
            <textevent timeoffset="0" message="Cooldown: easy spin, bring HR down gradually" />
            <textevent timeoffset="60" message="Your new FTP = avg power from test × 0.95" />
            <textevent timeoffset="180" message="Great work! Keep spinning to flush lactate" />
            <textevent timeoffset="360" message="Stretch on the bike, loosen shoulders" />
            <textevent timeoffset="540" message="Update your FTP in Zwift settings!" />
        </Cooldown>
    </workout>
</workout_file>
